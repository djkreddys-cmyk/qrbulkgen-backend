generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model bulk_jobs {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspace_id String?     @db.Uuid
  file_name    String?
  total_qr     Int?
  status       String?     @default("processing")
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  workspaces   workspaces? @relation(fields: [workspace_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model campaigns {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspace_id String?     @db.Uuid
  name         String
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  workspaces   workspaces? @relation(fields: [workspace_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  qrcodes      qrcodes[]
}

model qr_redirect_logs {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  qr_id        String?   @db.Uuid
  redirect_url String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  qrcodes      qrcodes?  @relation(fields: [qr_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model qrcodes {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workspace_id     String?            @db.Uuid
  campaign_id      String?            @db.Uuid
  type             String
  title            String?
  short_code       String             @unique
  target_url       String?
  data             Json?
  is_dynamic       Boolean?           @default(true)
  is_active        Boolean?           @default(true)
  expires_at       DateTime?          @db.Timestamp(6)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  qr_redirect_logs qr_redirect_logs[]
  campaigns        campaigns?         @relation(fields: [campaign_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workspaces       workspaces?        @relation(fields: [workspace_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scans            scans[]

  @@index([short_code], map: "idx_qr_shortcode")
  @@index([workspace_id], map: "idx_qr_workspace")
}

model scans {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  qr_id      String?   @db.Uuid
  ip_address String?
  country    String?
  city       String?
  device     String?
  browser    String?
  os         String?
  scanned_at DateTime? @default(now()) @db.Timestamp(6)
  qrcodes    qrcodes?  @relation(fields: [qr_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([qr_id], map: "idx_scans_qr")
}

model users {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String?
  email      String       @unique
  password   String?
  plan       String?      @default("free")
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  workspaces workspaces[]
}

model workspaces {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String
  owner_id   String?     @db.Uuid
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  bulk_jobs  bulk_jobs[]
  campaigns  campaigns[]
  qrcodes    qrcodes[]
  users      users?      @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
